<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
  <!-- Unique identifier of the plugin. It should be FQN. It cannot be changed between the plugin versions. -->
  <id>com.github.liguanyu.claudecodelauncher</id>

  <!-- Public plugin name should be written in Title Case.
       Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-name -->
  <name>ClaudeCode-launcher</name>

  <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
  <vendor url="https://github.com/liguanyu">liguanyu</vendor>

  <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
       Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-description -->
  <description><![CDATA[
        <blockquote><b>Important:</b> Install the <a href="https://docs.anthropic.com/en/docs/claude-code/overview">Claude Code CLI</a> separately before using this plugin.</blockquote>

        <blockquote><b>For Windows users:</b> Please select your terminal shell in the plugin settings (<em>Settings (→ Other Settings) → ClaudeCode-launcher</em>) to ensure proper functionality.</blockquote>

        <h2>Overview</h2>
        <p>
          ClaudeCode-launcher is an <b>unofficial</b> IntelliJ IDEA plugin that keeps the Claude Code CLI one click away inside the IDE.
        </p>

        <h2>Features</h2>
        <ul>
          <li><b>One-click launch</b> from the toolbar or Tools menu</li>
          <li><b>Integrated terminal</b> that opens a dedicated "Claude Code" tab in the project root</li>
          <li><b>Completion notifications</b> after Claude Code CLI finishes processing the current run</li>
          <li><b>Automatic file opening</b> for files updated by Claude Code</li>
          <li><b>Built-in MCP server pairing</b> with guided setup for IntelliJ's MCP server (2025.2+)</li>
          <li><b>Flexible configuration</b> for launch shells, models, permissions, tools, and notifications</li>
        </ul>

        <h2>Usage</h2>
        <ol>
          <li>Click the <b>Launch Claude Code</b> button in the main toolbar</li>
          <li>Or choose <b>Tools</b> → <b>Launch Claude Code</b></li>
          <li>The integrated terminal opens a new "Claude Code" tab and runs <code>claude</code> automatically</li>
        </ol>

        <h2>Configuration</h2>
        <p>Open <em>Settings (→ Other Settings) → ClaudeCode-launcher</em> to pick the launch shell, model, permission mode, tool options, notification behavior, and auto-open options.</p>

        <h2>Requirements</h2>
        <ul>
          <li>IntelliJ IDEA 2024.2 or later (or other compatible JetBrains IDEs)</li>
          <li>Claude Code CLI installed and available in your selected shell PATH</li>
        </ul>
    ]]></description>

  <!-- Product and plugin compatibility requirements.
       Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
  <depends>com.intellij.modules.platform</depends>
  <depends>org.jetbrains.plugins.terminal</depends>

  <!-- Extension points defined by the plugin.
       Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
  <extensions defaultExtensionNs="com.intellij">
    <notificationGroup id="ClaudeCodeLauncher" displayType="BALLOON" isLogByDefault="true"/>
    <applicationConfigurable instance="com.github.liguanyu.claudecodelauncher.settings.ui.ClaudeCodeLauncherConfigurable" id="com.github.liguanyu.claudecodelauncher.settings" displayName="ClaudeCode-launcher"/>
    <postStartupActivity implementation="com.github.liguanyu.claudecodelauncher.startup.ClaudeCodeStartupActivity"/>
  </extensions>

  <projectListeners>
    <listener class="com.github.liguanyu.claudecodelauncher.terminal.ProjectClosingListener"
              topic="com.intellij.openapi.project.ProjectManagerListener"/>
  </projectListeners>

  <actions>
    <action id="com.github.liguanyu.claudecodelauncher.launch"
      class="com.github.liguanyu.claudecodelauncher.actions.LaunchClaudeCodeAction"
      text="Launch Claude Code" description="Open a Claude Code terminal" icon="icons/claude_code.svg">
      <!-- New UI toolbar (2022.3+) -->
      <add-to-group group-id="MainToolbarRight" anchor="last"/>
      <add-to-group group-id="MainToolbarLeft" anchor="last"/>
      <!-- Fallback: old UI/NavBar toolbar -->
      <add-to-group group-id="NavBarToolBar" anchor="last"/>
      <!-- Also put it in the Tools menu for discoverability -->
      <add-to-group group-id="ToolsMenu" anchor="last"/>
    </action>
    <action id="com.github.liguanyu.claudecodelauncher.sendRange"
      class="com.github.liguanyu.claudecodelauncher.actions.SendRangeToClaudeCodeAction"
      text="Send Selection/Class to Claude Code"
      description="Send the current selection or enclosing class lines to the Claude Code terminal"
      icon="icons/claude_code_active.svg">
      <add-to-group group-id="EditorPopupMenu" anchor="after" relative-to-action="Copy"/>
      <add-to-group group-id="EditorTabPopupMenu" anchor="last"/>
      <add-to-group group-id="Floating.CodeToolbar" anchor="last"/>
    </action>
  </actions>
</idea-plugin>
